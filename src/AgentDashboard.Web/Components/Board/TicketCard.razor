@using Microsoft.AspNetCore.Components
@using AgentDashboard.TicketTracking.Application.Queries.GetBoard.Dtos
@using AgentDashboard.Web.Components.Shared
@using AspNetCore.Localizer.Json.Localizer
@inject IJsonStringLocalizer<TicketCard> Localizer

<div class="card @GetCardStateClass()" @key="TicketSnapshot">
    @if (TicketSnapshot.IsEscalated)
    {
        <span class="esc-badge"><span class="siren" aria-hidden="true">◆</span> @Localizer["Escalated"] → @TicketSnapshot.EscalationTargetId</span>
    }
    <div class="card-head">
        <span class="card-id mono">#@TicketSnapshot.Id</span>
        <span class="card-title">@TicketSnapshot.Title</span>
    </div>
    <div class="card-meta">
        @if (TicketSnapshot.IsInCrossReview && GetAgentFromId(TicketSnapshot.AgentId) is { } crossAgent)
        {
            <span class="cross">
                <AgentChip
                    Agent="crossAgent"
                    IsThinking="TicketSnapshot.IsThinking"
                    IsDense="true" />
                <span class="x">⇄</span>
                @if (GetAgentFromId(TicketSnapshot.CoAgentId) is { } coAgent)
                {
                    <AgentChip
                        Agent="coAgent"
                        IsDense="true" />
                }
            </span>
        }
        @if (!TicketSnapshot.IsInCrossReview && GetAgentFromId(TicketSnapshot.AgentId) is { } normalAgent)
        {
            <AgentChip
                Agent="normalAgent"
                IsThinking="TicketSnapshot.IsThinking"
                IsDense="false" />
        }
        <RetryCounter Current="TicketSnapshot.RetryCount" />
        <AgeBadge Age="@TicketSnapshot.Age" Freshness="@TicketSnapshot.Freshness" />
    </div>
</div>

@code {
    [Parameter, EditorRequired] public TicketDto TicketSnapshot { get; set; } = null!;
    [Parameter, EditorRequired] public IReadOnlyList<AgentDto> Agents { get; set; } = null!;

    private AgentDto? GetAgentFromId(string? agentId)
    {
        if (agentId == null) return null;
        return Agents.FirstOrDefault(a => a.Id == agentId);
    }

    private string GetCardStateClass()
    {
        if (TicketSnapshot.IsEscalated) return "escalated";
        if (TicketSnapshot.RetryCount >= 3) return "danger";
        if (TicketSnapshot.RetryCount == 2) return "warn";
        if (TicketSnapshot.Freshness == "Fresh") return "fresh";
        if (TicketSnapshot.Freshness == "Stale") return "stale";
        return "";
    }
}
