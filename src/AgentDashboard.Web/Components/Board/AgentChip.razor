@using Microsoft.AspNetCore.Components
@using AgentDashboard.TicketTracking.Domain.Agents

@if (Agent is null) return;

<span @class="GetAgentClass()" title="@($"{Agent.Role} — {Agent.Name}")">
    <span class="agent-glyph" aria-hidden="true">@Agent.Glyph</span>
    @if (!IsDense)
    {
        <span class="agent-name">@Agent.Name</span>
    }
</span>

@code {
    [Parameter, EditorRequired] public Agent? Agent { get; set; }
    [Parameter] public bool IsThinking { get; set; }
    [Parameter] public bool IsDense { get; set; }

    internal string GetAgentClass() => IsThinking ? "agent thinking" : "agent";
}
