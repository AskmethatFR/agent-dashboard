@using AgentDashboard.Web.Store
@using Blazor.Redux.Interfaces
@inject IAsyncDispatcher Dispatcher
@inject TimeProvider TimeProvider
@rendermode InteractiveServer

<button type="button"
        class="refresh-btn @StateCssClass"
        aria-label="Refresh tickets now"
        aria-busy="@(_isBusy ? "true" : "false")"
        title="Refresh tickets now"
        disabled="@_isBusy"
        @onclick="HandleClick">
    &#x27F3;
</button>

@code {
    private bool _isBusy;
    private DateTimeOffset _cooldownUntil;

    private string StateCssClass => _isBusy ? "is-busy" : string.Empty;

    private async Task HandleClick()
    {
        if (_isBusy)
        {
            return;
        }

        if (TimeProvider.GetUtcNow() < _cooldownUntil)
        {
            return;
        }

        _isBusy = true;
        try
        {
            await Dispatcher.DispatchAsync<BoardSlice, LoadBoardAction>(new LoadBoardAction());
            _cooldownUntil = TimeProvider.GetUtcNow() + TimeSpan.FromSeconds(1);
        }
        finally
        {
            _isBusy = false;
        }
    }
}
