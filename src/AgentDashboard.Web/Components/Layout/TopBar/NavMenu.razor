<nav class="nav" aria-label="primary">
    @foreach (var entry in Entries)
    {
        if (entry.IsActive)
        {
            <button type="button" class="nav-item active" aria-current="page">@entry.Label</button>
        }
        else
        {
            <button type="button" class="nav-item" disabled aria-disabled="true" title="Coming in v1.1+">@entry.Label</button>
        }
    }
</nav>

@code {
    private static readonly (string Label, bool IsActive)[] Entries =
    [
        ("Home", false),
        ("Team Board", true),
        ("Sessions", false),
        ("Replay", false),
        ("Agent", false),
        ("Flow", false),
        ("Escalations", false),
    ];
}
