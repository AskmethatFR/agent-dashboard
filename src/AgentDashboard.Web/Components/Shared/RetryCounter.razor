@using AgentDashboard.TicketTracking.Domain.Tickets
@using AspNetCore.Localizer.Json.Localizer
@inject IJsonStringLocalizer<RetryCounter> Localizer

<span 
    class="@GetRetryClass() retry-counter mono"
    aria-label="@GetAriaLabel()">
    <span class="retry-glyph" aria-hidden="true">⟳</span>
    <span class="retry-value">@Current</span>
    <span class="retry-max">/@Max</span>
</span>

@code {
    [Parameter, EditorRequired] public int Current { get; set; }
    [Parameter] public int Max { get; set; } = Retry.MaxBeforeEscalation;

    private string GetRetryClass()
    {
        if (Current >= Max) return "retry-danger";
        if (Current == Retry.WarnAt) return "retry-warn";
        return "retry-safe";
    }

    private string GetAriaLabel()
    {
        if (Current >= Max) return string.Format(Localizer["RetryCountAtMaximum"], Current, Max);
        if (Current == Retry.WarnAt) return string.Format(Localizer["RetryCountWarning"], Current, Max);
        return string.Format(Localizer["RetryCount"], Current, Max);
    }
}
